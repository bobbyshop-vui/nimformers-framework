    mul.wide.s32 %rd3, %r7, 4;
    add.s64 %rd4, %rd1, %rd3;
    add.s64 %rd5, %rd2, %rd3;

    ld.global.f32 %f1, [%rd4];
    mov.u32 %r8, 1;

