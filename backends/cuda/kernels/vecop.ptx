    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd8, %rd5, %rd6;
    ld.global.f32 %f5, [%rd8];
    mul.f32 %f7, %f5, %f6;
    st.global.f32 [%rd8], %f7;

    add.s32 %r8, %r8, 1;
