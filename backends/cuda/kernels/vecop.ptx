    setp.ge.s32 %p2, %r8, %r6;
    @%p2 bra BB_SM_MAX_DONE;

    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd7, %rd4, %rd6;
    ld.global.f32 %f2, [%rd7];
    setp.gt.f32 %p3, %f2, %f1;
    selp.f32 %f1, %f2, %f1, %p3;

    add.s32 %r8, %r8, 1;
    bra BB_SM_MAX_LOOP;

BB_SM_MAX_DONE:
    mov.f32 %f3, 0f00000000;
    mov.u32 %r8, 0;

BB_SM_EXP_LOOP:
    setp.ge.s32 %p2, %r8, %r6;
    @%p2 bra BB_SM_EXP_DONE;

    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd7, %rd4, %rd6;
    ld.global.f32 %f2, [%rd7];
    sub.f32 %f4, %f2, %f1;
    mul.f32 %f4, %f4, 0f3fb8aa3b;
    ex2.approx.f32 %f5, %f4;

    add.s64 %rd8, %rd5, %rd6;
    st.global.f32 [%rd8], %f5;
    add.f32 %f3, %f3, %f5;

    add.s32 %r8, %r8, 1;
    bra BB_SM_EXP_LOOP;

BB_SM_EXP_DONE:
    rcp.approx.f32 %f6, %f3;
    mov.u32 %r8, 0;

BB_SM_DIV_LOOP:
