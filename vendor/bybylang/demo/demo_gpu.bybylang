# Các phép toán GPU nâng cao
gpu layernorm A, B, C -> LAYERNORM_RES rows 8 cols 1 eps 1e-5

# Tạo indices riêng cho embedding (dùng biến thường, không phải gpu array)
indices = [0, 1, 2, 3, 4, 5, 6, 7]
gpu embedding E, indices -> EMBED_RES vocab 8 dim 8

print "GPU layernorm result:"
print LAYERNORM_RES
print "GPU embedding result:"
print EMBED_RES