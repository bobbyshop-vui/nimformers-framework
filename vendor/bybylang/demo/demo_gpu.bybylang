mode is 3

gpu backend is "opencl"
gpu array A = [1, 2, 3, 4, 5, 6, 7, 8]
gpu array B = [10, 20, 30, 40, 50, 60, 70, 80]
gpu array E = [10, 20, 30, 40, 50, 60, 70, 80, 100, 110, 120, 130, 134, 12122121123123123, 123123123]
gpu array O = [10, 20, 30, 40, 50, 60, 70, 80, 100, 110, 120, 130, 134, 12122121123123123, 123123123]
gpu add A, B -> C size 8
gpu mul A, B -> D size 8
gpu mul E, O -> G size 15
gpu sub A, B -> H size 8
gpu div A, B -> I size 8
gpu relu A -> J
gpu sigmoid A -> K
gpu tanh A -> L
gpu softmax A -> M rows 1 cols 8
gpu matmul A, B -> N m 8 k 8 n 1

print "GPU add result:"
