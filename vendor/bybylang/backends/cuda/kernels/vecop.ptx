// ============================================================
// VECOP RELU
// ============================================================
.visible .entry vecop_relu(
    .param .u64 vecop_relu_param_0,
    .param .u64 vecop_relu_param_1,
    .param .u32 vecop_relu_param_2
)
{
    .reg .pred %p<3>;
    .reg .f32 %f<3>;
    .reg .b32 %r<6>;
    .reg .b64 %rd<8>;

    ld.param.u64 %rd1, [vecop_relu_param_0];
    ld.param.u64 %rd2, [vecop_relu_param_1];
    ld.param.u32 %r2, [vecop_relu_param_2];
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r1, %r4, %r3, %r5;
    setp.ge.s32 %p1, %r1, %r2;
    @%p1 bra BB_RELU_2;

    cvta.to.global.u64 %rd3, %rd1;
    mul.wide.s32 %rd4, %r1, 4;
    add.s64 %rd5, %rd3, %rd4;
    ld.global.nc.f32 %f1, [%rd5];
    
    setp.lt.f32 %p2, %f1, 0f00000000;
    selp.f32 %f2, 0f00000000, %f1, %p2;

    cvta.to.global.u64 %rd6, %rd2;
    add.s64 %rd7, %rd6, %rd4;
    st.global.f32 [%rd7], %f2;

BB_RELU_2:
    ret;
}

// ============================================================
// VECOP SIGMOID
// ============================================================
.visible .entry vecop_sigmoid(
    .param .u64 vecop_sigmoid_param_0,
    .param .u64 vecop_sigmoid_param_1,
    .param .u32 vecop_sigmoid_param_2
)
{
    .reg .pred %p<2>;
    .reg .f32 %f<6>;
    .reg .b32 %r<6>;
    .reg .b64 %rd<8>;

    ld.param.u64 %rd1, [vecop_sigmoid_param_0];
    ld.param.u64 %rd2, [vecop_sigmoid_param_1];
    ld.param.u32 %r2, [vecop_sigmoid_param_2];
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r1, %r4, %r3, %r5;
    setp.ge.s32 %p1, %r1, %r2;
    @%p1 bra BB_SIG_2;

    cvta.to.global.u64 %rd3, %rd1;
    mul.wide.s32 %rd4, %r1, 4;
    add.s64 %rd5, %rd3, %rd4;
    ld.global.nc.f32 %f1, [%rd5];

    neg.f32 %f2, %f1;
    mul.f32 %f2, %f2, 0f3fb8aa3b;
    ex2.approx.f32 %f3, %f2;
    add.f32 %f4, %f3, 0f3f800000;
    rcp.approx.f32 %f5, %f4;

    cvta.to.global.u64 %rd6, %rd2;
    add.s64 %rd7, %rd6, %rd4;
    st.global.f32 [%rd7], %f5;

BB_SIG_2:
    ret;
}

// ============================================================
// VECOP TANH
// ============================================================
.visible .entry vecop_tanh(
    .param .u64 vecop_tanh_param_0,
    .param .u64 vecop_tanh_param_1,
    .param .u32 vecop_tanh_param_2
)
{
    .reg .pred %p<2>;
    .reg .f32 %f<10>;
    .reg .b32 %r<6>;
    .reg .b64 %rd<8>;

    ld.param.u64 %rd1, [vecop_tanh_param_0];
    ld.param.u64 %rd2, [vecop_tanh_param_1];
    ld.param.u32 %r2, [vecop_tanh_param_2];
    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r1, %r4, %r3, %r5;
    setp.ge.s32 %p1, %r1, %r2;
    @%p1 bra BB_TANH_2;

    cvta.to.global.u64 %rd3, %rd1;
    mul.wide.s32 %rd4, %r1, 4;
    add.s64 %rd5, %rd3, %rd4;
    ld.global.nc.f32 %f1, [%rd5];

    mul.f32 %f2, %f1, 0f40000000;
    mul.f32 %f2, %f2, 0f3fb8aa3b;
    ex2.approx.f32 %f3, %f2;
    sub.f32 %f4, %f3, 0f3f800000;
    add.f32 %f5, %f3, 0f3f800000;
    rcp.approx.f32 %f6, %f5;
    mul.f32 %f7, %f4, %f6;

    cvta.to.global.u64 %rd6, %rd2;
    add.s64 %rd7, %rd6, %rd4;
    st.global.f32 [%rd7], %f7;

BB_TANH_2:
    ret;
}

// ============================================================
// VECOP APFLU (Forward)
// ============================================================
.visible .entry vecop_apflu(
    .param .u64 apflu_param_0,
    .param .u64 apflu_param_1,
    .param .u32 apflu_param_2,
    .param .f32 apflu_param_3,
    .param .f32 apflu_param_4
)
{
    .reg .pred %p<3>;
    .reg .f32 %f<8>;
    .reg .b32 %r<6>;
    .reg .b64 %rd<8>;

    ld.param.u64 %rd1, [apflu_param_0];
    ld.param.u64 %rd2, [apflu_param_1];
    ld.param.u32 %r2, [apflu_param_2];
    ld.param.f32 %f1, [apflu_param_3];   // alpha
    ld.param.f32 %f2, [apflu_param_4];   // beta

    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r1, %r4, %r3, %r5;
    setp.ge.s32 %p1, %r1, %r2;
    @%p1 bra BB_APFLU_RET;

    cvta.to.global.u64 %rd3, %rd1;
    mul.wide.s32 %rd4, %r1, 4;
    add.s64 %rd5, %rd3, %rd4;
    ld.global.nc.f32 %f3, [%rd5];

    // APFLU: x*(1+alpha*x) if x>0 else beta*x*exp(x)
    setp.gt.f32 %p2, %f3, 0f00000000;
    @%p2 bra BB_APFLU_POS;

    // x <= 0: beta * x * exp(x)
    mul.f32 %f4, %f3, 0f3fb8aa3b;
    ex2.approx.f32 %f5, %f4;
    mul.f32 %f6, %f2, %f3;
    mul.f32 %f7, %f6, %f5;
    cvta.to.global.u64 %rd6, %rd2;
    add.s64 %rd7, %rd6, %rd4;
    st.global.f32 [%rd7], %f7;
    bra BB_APFLU_RET;

BB_APFLU_POS:
    // x > 0: x * (1 + alpha * x)
    fma.rn.f32 %f4, %f1, %f3, 0f3f800000;
    mul.f32 %f5, %f3, %f4;
    cvta.to.global.u64 %rd6, %rd2;
    add.s64 %rd7, %rd6, %rd4;
    st.global.f32 [%rd7], %f5;

BB_APFLU_RET:
    ret;
}

// ============================================================
// VECOP APFLU BACKWARD
// ============================================================
.visible .entry vecop_apflu_backward(
    .param .u64 apflu_bwd_param_0,
    .param .u64 apflu_bwd_param_1,
    .param .u64 apflu_bwd_param_2,
    .param .u32 apflu_bwd_param_3,
    .param .f32 apflu_bwd_param_4,
    .param .f32 apflu_bwd_param_5
)
{
    .reg .pred %p<3>;
    .reg .f32 %f<11>;
    .reg .b32 %r<6>;
    .reg .b64 %rd<11>;

    ld.param.u64 %rd1, [apflu_bwd_param_0];
    ld.param.u64 %rd2, [apflu_bwd_param_1];
    ld.param.u64 %rd3, [apflu_bwd_param_2];
    ld.param.u32 %r2, [apflu_bwd_param_3];
    ld.param.f32 %f1, [apflu_bwd_param_4];
    ld.param.f32 %f2, [apflu_bwd_param_5];

    mov.u32 %r3, %ntid.x;
    mov.u32 %r4, %ctaid.x;
    mov.u32 %r5, %tid.x;
    mad.lo.s32 %r1, %r4, %r3, %r5;
    setp.ge.s32 %p1, %r1, %r2;
    @%p1 bra BB_APFLU_BWD_RET;

    cvta.to.global.u64 %rd4, %rd1;
    mul.wide.s32 %rd5, %r1, 4;
    add.s64 %rd6, %rd4, %rd5;
    ld.global.nc.f32 %f3, [%rd6];  // x

    cvta.to.global.u64 %rd7, %rd2;
    add.s64 %rd8, %rd7, %rd5;
    ld.global.nc.f32 %f4, [%rd8];  // dy

    setp.gt.f32 %p2, %f3, 0f00000000;
    @%p2 bra BB_APFLU_BWD_POS;

    // x <= 0: d * beta * exp(x) * (1 + x)
    mul.f32 %f5, %f3, 0f3fb8aa3b;
    ex2.approx.f32 %f6, %f5;
    mul.f32 %f7, %f2, %f4;
    mul.f32 %f8, %f7, %f6;
    add.f32 %f9, %f3, 0f3f800000;
    mul.f32 %f10, %f8, %f9;
    cvta.to.global.u64 %rd9, %rd3;
    add.s64 %rd10, %rd9, %rd5;
    st.global.f32 [%rd10], %f10;
    bra BB_APFLU_BWD_RET;

BB_APFLU_BWD_POS:
    // x > 0: d * (1 + 2*alpha*x)
    mul.f32 %f5, %f1, 0f40000000;
    fma.rn.f32 %f6, %f5, %f3, 0f3f800000;
    mul.f32 %f7, %f4, %f6;
    cvta.to.global.u64 %rd9, %rd3;
    add.s64 %rd10, %rd9, %rd5;
    st.global.f32 [%rd10], %f7;

BB_APFLU_BWD_RET:
    ret;
}

// ============================================================
// EMBEDDING LOOKUP
// ============================================================
.visible .entry embedding_lookup_kernel(
    .param .u64 el_param_0,
    .param .u64 el_param_1,
    .param .u64 el_param_2,
    .param .u32 el_param_3,
    .param .u32 el_param_4,
    .param .u32 el_param_5
)
{
    .reg .pred %p<3>;
    .reg .b32 %r<10>;
    .reg .f32 %f<2>;
    .reg .b64 %rd<14>;

    mov.u32 %r1, %ntid.x;
    mov.u32 %r2, %ctaid.x;
    mov.u32 %r3, %tid.x;
    mad.lo.s32 %r4, %r2, %r1, %r3;

    ld.param.u32 %r5, [el_param_5];
    setp.ge.s32 %p1, %r4, %r5;
    @%p1 bra BB_EL_RET;

    ld.param.u64 %rd1, [el_param_0];
    ld.param.u64 %rd2, [el_param_1];
    ld.param.u64 %rd3, [el_param_2];
    ld.param.u32 %r6, [el_param_3];
    ld.param.u32 %r7, [el_param_4];

    cvta.to.global.u64 %rd4, %rd2;
    mul.wide.s32 %rd5, %r4, 4;
    add.s64 %rd6, %rd4, %rd5;
    ld.global.s32 %r8, [%rd6];

    setp.lt.s32 %p2, %r8, 0;
    @%p2 bra BB_EL_ZERO;
    setp.ge.s32 %p2, %r8, %r6;
    @%p2 bra BB_EL_ZERO;

    mul.lo.s32 %r9, %r8, %r7;
    mul.wide.s32 %rd7, %r9, 4;
    add.s64 %rd8, %rd1, %rd7;

    mul.lo.s32 %r9, %r4, %r7;
    mul.wide.s32 %rd9, %r9, 4;
    add.s64 %rd10, %rd3, %rd9;

    mov.u32 %r8, 0;

BB_EL_LOOP:
    setp.ge.s32 %p2, %r8, %r7;
    @%p2 bra BB_EL_RET;

    mul.wide.s32 %rd11, %r8, 4;
    add.s64 %rd12, %rd8, %rd11;
    ld.global.f32 %f1, [%rd12];

    add.s64 %rd13, %rd10, %rd11;
    st.global.f32 [%rd13], %f1;

    add.s32 %r8, %r8, 1;
    bra BB_EL_LOOP;

BB_EL_ZERO:
    mul.lo.s32 %r9, %r4, %r7;
    mul.wide.s32 %rd9, %r9, 4;
    add.s64 %rd10, %rd3, %rd9;

    mov.u32 %r8, 0;

BB_EL_ZERO_LOOP:
    setp.ge.s32 %p2, %r8, %r7;
    @%p2 bra BB_EL_RET;

    mul.wide.s32 %rd11, %r8, 4;
    add.s64 %rd13, %rd10, %rd11;
    st.global.f32 [%rd13], 0f00000000;

    add.s32 %r8, %r8, 1;
    bra BB_EL_ZERO_LOOP;

BB_EL_RET:
    ret;
}

// ============================================================
// SOFTMAX - Block size 512 cho T4
// ============================================================
.visible .entry softmax_kernel(
    .param .u64 softmax_param_0,
    .param .u64 softmax_param_1,
    .param .u32 softmax_param_2,
    .param .u32 softmax_param_3
)
{
    .reg .pred %p<6>;
    .reg .b32 %r<30>;
    .reg .f32 %f<20>;
    .reg .b64 %rd<20>;
    .shared .align 4 .b8 sred_sm[2048];

    mov.u32 %r1, %ctaid.x;
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, sred_sm;
    shl.b32 %r4, %r2, 2;
    add.s32 %r5, %r3, %r4;

    ld.param.u64 %rd1, [softmax_param_0];
    ld.param.u64 %rd2, [softmax_param_1];
    ld.param.u32 %r6, [softmax_param_3];

    mul.lo.s32 %r7, %r1, %r6;
    mul.wide.s32 %rd3, %r7, 4;
    add.s64 %rd4, %rd1, %rd3;
    add.s64 %rd5, %rd2, %rd3;

    mov.f32 %f1, 0fFF800000;
    mov.u32 %r8, %r2;

BB_SM_MAX_LOOP:
    setp.ge.s32 %p1, %r8, %r6;
    @%p1 bra BB_SM_MAX_DONE;

    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd7, %rd4, %rd6;
    ld.global.nc.f32 %f2, [%rd7];
    setp.gt.f32 %p2, %f2, %f1;
    selp.f32 %f1, %f2, %f1, %p2;

    add.s32 %r8, %r8, 512;
    bra BB_SM_MAX_LOOP;

BB_SM_MAX_DONE:
    st.shared.f32 [%r5], %f1;
    bar.sync 0;

    mov.u32 %r9, 256;
BB_SM_MAX_RED:
    setp.ge.u32 %p3, %r2, %r9;
    @%p3 bra BB_SM_MAX_RED_SKIP;
    add.s32 %r10, %r2, %r9;
    shl.b32 %r11, %r10, 2;
    add.s32 %r12, %r3, %r11;
    ld.shared.f32 %f3, [%r12];
    ld.shared.f32 %f4, [%r5];
    setp.gt.f32 %p4, %f3, %f4;
    selp.f32 %f4, %f3, %f4, %p4;
    st.shared.f32 [%r5], %f4;
BB_SM_MAX_RED_SKIP:
    bar.sync 0;
    shr.u32 %r9, %r9, 1;
    setp.gt.u32 %p5, %r9, 0;
    @%p5 bra BB_SM_MAX_RED;

    ld.shared.f32 %f1, [%r3];
    bar.sync 0;

    mov.f32 %f5, 0f00000000;
    mov.u32 %r8, %r2;

BB_SM_EXP_LOOP:
    setp.ge.s32 %p1, %r8, %r6;
    @%p1 bra BB_SM_EXP_DONE;

    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd7, %rd4, %rd6;
    ld.global.nc.f32 %f2, [%rd7];
    sub.f32 %f6, %f2, %f1;
    mul.f32 %f6, %f6, 0f3fb8aa3b;
    ex2.approx.f32 %f7, %f6;

    add.s64 %rd8, %rd5, %rd6;
    st.global.f32 [%rd8], %f7;
    add.f32 %f5, %f5, %f7;

    add.s32 %r8, %r8, 512;
    bra BB_SM_EXP_LOOP;

BB_SM_EXP_DONE:
    st.shared.f32 [%r5], %f5;
    bar.sync 0;

    mov.u32 %r9, 256;
BB_SM_SUM_RED:
    setp.ge.u32 %p3, %r2, %r9;
    @%p3 bra BB_SM_SUM_RED_SKIP;
    add.s32 %r10, %r2, %r9;
    shl.b32 %r11, %r10, 2;
    add.s32 %r12, %r3, %r11;
    ld.shared.f32 %f3, [%r12];
    ld.shared.f32 %f4, [%r5];
    add.f32 %f4, %f4, %f3;
    st.shared.f32 [%r5], %f4;
BB_SM_SUM_RED_SKIP:
    bar.sync 0;
    shr.u32 %r9, %r9, 1;
    setp.gt.u32 %p5, %r9, 0;
    @%p5 bra BB_SM_SUM_RED;

    ld.shared.f32 %f5, [%r3];
    rcp.approx.f32 %f8, %f5;
    bar.sync 0;

    mov.u32 %r8, %r2;
BB_SM_DIV_LOOP:
    setp.ge.s32 %p1, %r8, %r6;
    @%p1 bra BB_SM_RET;

    mul.wide.s32 %rd6, %r8, 4;
    add.s64 %rd8, %rd5, %rd6;
    ld.global.f32 %f9, [%rd8];
    mul.f32 %f9, %f9, %f8;
    st.global.f32 [%rd8], %f9;

    add.s32 %r8, %r8, 512;
    bra BB_SM_DIV_LOOP;

BB_SM_RET:
    ret;
}

// ============================================================
// LAYERNORM FORWARD - Block size 512
// ============================================================
.visible .entry layernorm_kernel(
    .param .u64 ln_param_0,
    .param .u64 ln_param_1,
    .param .u64 ln_param_2,
    .param .u64 ln_param_3,
    .param .u32 ln_param_4,
    .param .u32 ln_param_5,
    .param .f32 ln_param_6
)
{
    .reg .pred %p<6>;
    .reg .b32 %r<30>;
    .reg .f32 %f<24>;
    .reg .b64 %rd<20>;
    .shared .align 4 .b8 sred_ln[2048];

    mov.u32 %r1, %ctaid.x;
    mov.u32 %r2, %tid.x;
    mov.u32 %r3, sred_ln;
    shl.b32 %r4, %r2, 2;
    add.s32 %r5, %r3, %r4;

    ld.param.u64 %rd1, [ln_param_0];
    ld.param.u64 %rd2, [ln_param_1];
    ld.param.u64 %rd3, [ln_param_2];
    ld.param.u64 %rd4, [ln_param_3];
    ld.param.u32 %r6, [ln_param_5];
    ld.param.f32 %f1, [ln_param_6];

    mul.lo.s32 %r7, %r1, %r6;
    mul.wide.s32 %rd5, %r7, 4;
    add.s64 %rd6, %rd1, %rd5;
    add.s64 %rd7, %rd4, %rd5;

    mov.f32 %f2, 0f00000000;
    mov.f32 %f3, 0f00000000;
    mov.u32 %r8, %r2;

BB_LN_ACC_LOOP:
    setp.ge.s32 %p1, %r8, %r6;
    @%p1 bra BB_LN_ACC_DONE;

    mul.wide.s32 %rd8, %r8, 4;
    add.s64 %rd9, %rd6, %rd8;
    ld.global.nc.f32 %f4, [%rd9];
    add.f32 %f2, %f2, %f4;
    fma.rn.f32 %f3, %f4, %f4, %f3;

    add.s32 %r8, %r8, 512;
    bra BB_LN_ACC_LOOP;

BB_LN_ACC_DONE:
    st.shared.f32 [%r5], %f2;
    bar.sync 0;
    mov.u32 %r9, 256;

BB_LN_SUM_RED:
    setp.ge.u32 %p2, %r2, %r9;
    @%p2 bra BB_LN_SUM_RED_SKIP;
    add.s32 %r10, %r2, %r9;
    shl.b32 %r11, %r10, 2;
    add.s32 %r12, %r3, %r11;
    ld.shared.f32 %f5, [%r12];
    ld.shared.f32 %f6, [%r5];
    add.f32 %f6, %f6, %f5;
    st.shared.f32 [%r5], %f6;
BB_LN_SUM_RED_SKIP:
    bar.sync 0;
    shr.u32 %r9, %r9, 1;
    setp.gt.u32 %p3, %r9, 0;
    @%p3 bra BB_LN_SUM_RED;

    ld.shared.f32 %f2, [%r3];
    bar.sync 0;

    st.shared.f32 [%r5], %f3;
    bar.sync 0;
    mov.u32 %r9, 256;

BB_LN_SUMSQ_RED:
    setp.ge.u32 %p2, %r2, %r9;
    @%p2 bra BB_LN_SUMSQ_RED_SKIP;
    add.s32 %r10, %r2, %r9;
    shl.b32 %r11, %r10, 2;
    add.s32 %r12, %r3, %r11;
    ld.shared.f32 %f5, [%r12];
    ld.shared.f32 %f6, [%r5];
    add.f32 %f6, %f6, %f5;
    st.shared.f32 [%r5], %f6;
BB_LN_SUMSQ_RED_SKIP:
    bar.sync 0;
    shr.u32 %r9, %r9, 1;
    setp.gt.u32 %p3, %r9, 0;
    @%p3 bra BB_LN_SUMSQ_RED;

    ld.shared.f32 %f3, [%r3];

    cvt.rn.f32.s32 %f7, %r6;
    rcp.approx.f32 %f8, %f7;
    mul.f32 %f9, %f2, %f8;
    mul.f32 %f10, %f3, %f8;
    mul.f32 %f11, %f9, %f9;
    sub.f32 %f12, %f10, %f11;
    add.f32 %f13, %f12, %f1;
    rsqrt.approx.f32 %f14, %f13;
    bar.sync 0;

    mov.u32 %r8, %r2;
BB_LN_NORM_LOOP:
    setp.ge.s32 %p1, %r8, %r6;
    @%p1 bra BB_LN_RET;

    mul.wide.s32 %rd8, %r8, 4;
    add.s64 %rd9, %rd6, %rd8;
    ld.global.nc.f32 %f4, [%rd9];
    sub.f32 %f15, %f4, %f9;
    mul.f32 %f16, %f15, %f14;

    add.s64 %rd10, %rd2, %rd8;
    ld.global.nc.f32 %f17, [%rd10];
    add.s64 %rd11, %rd3, %rd8;
    ld.global.nc.f32 %f18, [%rd11];

    fma.rn.f32 %f16, %f16, %f17, %f18;

    add.s64 %rd12, %rd7, %rd8;
    st.global.f32 [%rd12], %f16;

    add.s32 %r8, %r8, 512;
    bra BB_LN_NORM_LOOP;

BB_LN_RET:
    ret;
}

// ============================================================
// LAYERNORM BACKWARD
// ============================================================
.visible .entry layernorm_backward_kernel(
    .param .u64 ln_bwd_param_0,
    .param .u64 ln_bwd_param_1,
    .param .u64 ln_bwd_param_2,
    .param .u64 ln_bwd_param_3,
    .param .u64 ln_bwd_param_4,
    .param .u64 ln_bwd_param_5,
    .param .u64 ln_bwd_param_6,
    .param .u32 ln_bwd_param_7,
    .param .u32 ln_bwd_param_8,
    .param .f32 ln_bwd_param_9
)
{
    .reg .pred %p<4>;
    .reg .b32 %r<30>;
    .reg .f32 %f<30>;
    .reg .b64 %rd<25>;

    mov.u32 %r1, %ctaid.x;
    mov.u32 %r29, %ntid.x;
    mov.u32 %r2, %tid.x;
    mad.lo.s32 %r2, %r1, %r29, %r2;   // FIX: global id = ctaid*ntid+tid (was tid.x only -> multiple blocks wrote same addresses -> race/illegal memory access -> D2H failed)

    ld.param.u32 %r3, [ln_bwd_param_7];
    ld.param.u32 %r4, [ln_bwd_param_8];
    ld.param.f32 %f1, [ln_bwd_param_9];

    ld.param.u64 %rd1, [ln_bwd_param_0];
    ld.param.u64 %rd2, [ln_bwd_param_1];
    ld.param.u64 %rd3, [ln_bwd_param_2];
    ld.param.u64 %rd4, [ln_bwd_param_3];
    ld.param.u64 %rd5, [ln_bwd_param_4];
    ld.param.u64 %rd6, [ln_bwd_param_5];
    ld.param.u64 %rd7, [ln_bwd_param_6];

    // Tinh dgamma, dbeta cho moi col (tid < cols)
    setp.ge.u32 %p1, %r2, %r4;
    @%p1 bra BB_LN_BWD_SKIP_DG;

    mov.f32 %f2, 0f00000000;
    mov.f32 %f3, 0f00000000;
    mov.u32 %r5, 0;

BB_LN_BWD_DG_LOOP:
    setp.ge.u32 %p2, %r5, %r3;
    @%p2 bra BB_LN_BWD_DG_DONE;

    mul.lo.s32 %r6, %r5, %r4;
    add.s32 %r7, %r6, %r2;
    mul.wide.s32 %rd8, %r7, 4;

    // Tinh mean, var
    mov.f32 %f4, 0f00000000;
    mov.f32 %f5, 0f00000000;
    mov.u32 %r8, 0;

BB_LN_BWD_MEAN_LOOP:
    setp.ge.u32 %p3, %r8, %r4;
    @%p3 bra BB_LN_BWD_MEAN_DONE;

    mul.lo.s32 %r9, %r5, %r4;
    add.s32 %r10, %r9, %r8;
    mul.wide.s32 %rd9, %r10, 4;
    add.s64 %rd10, %rd2, %rd9;
    ld.global.nc.f32 %f6, [%rd10];
    add.f32 %f4, %f4, %f6;
    fma.rn.f32 %f5, %f6, %f6, %f5;

    add.s32 %r8, %r8, 1;
    bra BB_LN_BWD_MEAN_LOOP;

BB_LN_BWD_MEAN_DONE:
    cvt.rn.f32.s32 %f7, %r4;
    rcp.approx.f32 %f8, %f7;
    mul.f32 %f9, %f4, %f8;
    mul.f32 %f10, %f5, %f8;
    mul.f32 %f11, %f9, %f9;
    sub.f32 %f12, %f10, %f11;
    add.f32 %f13, %f12, %f1;
    rsqrt.approx.f32 %f14, %f13;

    // dgamma += dy * (x - mean) * invStd
    add.s64 %rd11, %rd1, %rd8;
    ld.global.nc.f32 %f15, [%rd11];
    add.s64 %rd12, %rd2, %rd8;
    ld.global.nc.f32 %f16, [%rd12];
    sub.f32 %f17, %f16, %f9;
    mul.f32 %f18, %f17, %f14;
    fma.rn.f32 %f2, %f15, %f18, %f2;

    // dbeta += dy
    fma.rn.f32 %f3, %f15, 1.0, %f3;

    add.s32 %r5, %r5, 1;
    bra BB_LN_BWD_DG_LOOP;

BB_LN_BWD_DG_DONE:
    add.s64 %rd13, %rd6, %rd8;
    st.global.f32 [%rd13], %f2;
    add.s64 %rd14, %rd7, %rd8;
    st.global.f32 [%rd14], %f3;

BB_LN_BWD_SKIP_DG:

    // dx cho moi row (tid < rows)
    setp.ge.u32 %p2, %r2, %r3;
    @%p2 bra BB_LN_BWD_RET;

    mul.lo.s32 %r11, %r2, %r4;
    mul.wide.s32 %rd15, %r11, 4;

    // Tinh mean va var cho row nay
    mov.f32 %f4, 0f00000000;
    mov.f32 %f5, 0f00000000;
    mov.u32 %r8, 0;

BB_LN_BWD_ROW_MEAN_LOOP:
    setp.ge.u32 %p3, %r8, %r4;
    @%p3 bra BB_LN_BWD_ROW_MEAN_DONE;

    add.s64 %rd16, %rd2, %rd15;
    ld.global.nc.f32 %f6, [%rd16];
    add.f32 %f4, %f4, %f6;
    fma.rn.f32 %f5, %f6, %f6, %f5;

    add.s32 %r8, %r8, 1;
    bra BB_LN_BWD_ROW_MEAN_LOOP;

BB_LN_BWD_ROW_MEAN_DONE:
    cvt.rn.f32.s32 %f7, %r4;
    rcp.approx.f32 %f8, %f7;
    mul.f32 %f9, %f4, %f8;
    mul.f32 %f10, %f5, %f8;
    mul.f32 %f11, %f9, %f9;
    sub.f32 %f12, %f10, %f11;
    add.f32 %f13, %f12, %f1;
    rsqrt.approx.f32 %f14, %f13;

    // sum1 va sum2
    mov.f32 %f15, 0f00000000;
    mov.f32 %f16, 0f00000000;
    mov.u32 %r8, 0;

BB_LN_BWD_DX_SUM_LOOP:
    setp.ge.u32 %p3, %r8, %r4;
    @%p3 bra BB_LN_BWD_DX_SUM_DONE;

    add.s64 %rd17, %rd1, %rd15;
    ld.global.nc.f32 %f17, [%rd17];
    add.s64 %rd18, %rd3, %rd8;
    ld.global.nc.f32 %f18, [%rd18];
    add.s64 %rd19, %rd2, %rd15;
    ld.global.nc.f32 %f19, [%rd19];

    mul.f32 %f20, %f17, %f18;
    mul.f32 %f20, %f20, %f14;
    fma.rn.f32 %f15, %f20, 1.0, %f15;
    sub.f32 %f21, %f19, %f9;
    fma.rn.f32 %f16, %f20, %f21, %f16;

    add.s32 %r8, %r8, 1;
    bra BB_LN_BWD_DX_SUM_LOOP;

BB_LN_BWD_DX_SUM_DONE:
    mul.f32 %f22, %f14, %f14;
    mul.f32 %f22, %f22, %f8;
    neg.f32 %f16, %f16;
    mul.f32 %f16, %f16, %f22;

    mov.u32 %r8, 0;

BB_LN_BWD_DX_LOOP:
    setp.ge.u32 %p3, %r8, %r4;
    @%p3 bra BB_LN_BWD_DX_DONE;

    add.s64 %rd20, %rd5, %rd15;
    add.s64 %rd21, %rd1, %rd15;
    add.s64 %rd22, %rd3, %rd8;
    add.s64 %rd23, %rd2, %rd15;

    ld.global.nc.f32 %f17, [%rd21];
    ld.global.nc.f32 %f18, [%rd22];
    ld.global.nc.f32 %f19, [%rd23];

    mul.f32 %f23, %f17, %f18;
    mul.f32 %f23, %f23, %f14;
    mul.f32 %f24, %f15, %f8;
    sub.f32 %f25, %f19, %f9;
    mul.f32 %f26, %f16, 0f40000000;
    mul.f32 %f26, %f26, %f8;
    mul.f32 %f26, %f25, %f26;

    sub.f32 %f27, %f23, %f24;
    add.f32 %f28, %f27, %f26;

    add.s64 %rd24, %rd4, %rd15;
    st.global.f32 [%rd24], %f28;

    add.s32 %r8, %r8, 1;
    bra BB_LN_BWD_DX_LOOP;

BB_LN_BWD_DX_DONE:

BB_LN_BWD_RET:
    ret;
}

// ============================================================
// ATTENTION FUSED FORWARD
// ============================================================
.visible .entry attention_fused_kernel(
    .param .u64 attn_param_0,
    .param .u64 attn_param_1,
    .param .u64 attn_param_2,
    .param .u64 attn_param_3,
    .param .u64 attn_param_4,
    .param .u32 attn_param_5,
    .param .u32 attn_param_6,
    .param .u32 attn_param_7,
    .param .u32 attn_param_8,
    .param .f32 attn_param_9
)
{
    .reg .pred %p<10>;
    .reg .b32 %r<100>;
    .reg .f32 %f<60>;
    .reg .b64 %rd<60>;
    .shared .align 4 .f32 scores[256];
    .shared .align 4 .f32 redBuf[512];

    // grid = (B*H, S, 1) ; block = (blockSize, 1, 1)
    // moi block xu ly 1 hang query (bh, i), song song hoa qua cac thread theo j (key) va d (dim)
    mov.u32 %r1, %ctaid.x;      // bh
    mov.u32 %r2, %ctaid.y;      // i (query row)
    mov.u32 %r3, %tid.x;        // t
    mov.u32 %r4, %ntid.x;       // blockDim

    ld.param.u32 %r5, [attn_param_5];   // B
    ld.param.u32 %r6, [attn_param_6];   // H
    ld.param.u32 %r7, [attn_param_7];   // S (seqlen)
    ld.param.u32 %r8, [attn_param_8];   // D (head dim)
    ld.param.f32 %f1, [attn_param_9];   // scale

    mul.lo.s32 %r9, %r5, %r6;           // B*H
    setp.ge.u32 %p1, %r1, %r9;
    @%p1 bra BB_ATTN_RET;
    setp.ge.u32 %p2, %r2, %r7;
    @%p2 bra BB_ATTN_RET;

    ld.param.u64 %rd1, [attn_param_0];  // Q
    ld.param.u64 %rd2, [attn_param_1];  // K
    ld.param.u64 %rd3, [attn_param_2];  // V
    ld.param.u64 %rd4, [attn_param_3];  // Out
    ld.param.u64 %rd5, [attn_param_4];  // S_matrix

    mov.u64 %rd6, scores;
    mov.u64 %rd7, redBuf;

    mul.lo.s32 %r10, %r1, %r7;          // bh*S
    add.s32 %r11, %r10, %r2;            // rowIdx = bh*S+i
    mul.lo.s32 %r12, %r11, %r8;         // rowIdx*D
    mul.lo.s32 %r13, %r11, %r7;         // rowIdx*S

    mul.wide.s32 %rd8, %r12, 4;
    add.s64 %rd9, %rd1, %rd8;           // &Q[i,0]
    add.s64 %rd10, %rd4, %rd8;          // &Out[i,0]
    mul.wide.s32 %rd11, %r13, 4;
    add.s64 %rd12, %rd5, %rd11;         // &S_matrix[i,0]

    // ================= PHASE A: scores[j] = scale * Q_i . K_j =================
    mov.f32 %f2, 0fFF800000;            // threadMax = -inf
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_SCORE_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_SCORE_DONE;

    add.s32 %r15, %r10, %r14;           // bh*S + j
    mul.lo.s32 %r16, %r15, %r8;         // (bh*S+j)*D
    mul.wide.s32 %rd13, %r16, 4;
    add.s64 %rd14, %rd2, %rd13;         // &K[j,0]

    mov.f32 %f3, 0f00000000;            // dot accum
    mov.u32 %r17, 0;                    // d

BB_ATTN_DOT_LOOP:
    setp.ge.u32 %p3, %r17, %r8;
    @%p3 bra BB_ATTN_DOT_DONE;

    mul.wide.s32 %rd15, %r17, 4;
    add.s64 %rd16, %rd9, %rd15;
    ld.global.nc.f32 %f4, [%rd16];      // Q[i,d]
    add.s64 %rd17, %rd14, %rd15;
    ld.global.nc.f32 %f5, [%rd17];      // K[j,d]
    fma.rn.f32 %f3, %f4, %f5, %f3;

    add.s32 %r17, %r17, 1;
    bra BB_ATTN_DOT_LOOP;

BB_ATTN_DOT_DONE:
    mul.f32 %f3, %f3, %f1;              // *scale

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd19, %rd6, %rd18;
    st.shared.f32 [%rd19], %f3;         // scores[j] = score

    setp.gt.f32 %p3, %f3, %f2;
    selp.f32 %f2, %f3, %f2, %p3;        // threadMax = max(threadMax, score)

    add.s32 %r14, %r14, %r4;            // j += ntid
    bra BB_ATTN_SCORE_LOOP;

BB_ATTN_SCORE_DONE:

    // ---- block-wide max reduction ----
    mul.wide.s32 %rd20, %r3, 4;
    add.s64 %rd21, %rd7, %rd20;
    st.shared.f32 [%rd21], %f2;         // redBuf[t] = threadMax
    bar.sync 0;

    shr.u32 %r18, %r4, 1;               // stride = blockDim/2

BB_ATTN_MAXRED_LOOP:
    setp.eq.u32 %p3, %r18, 0;
    @%p3 bra BB_ATTN_MAXRED_DONE;

    setp.ge.u32 %p4, %r3, %r18;
    @%p4 bra BB_ATTN_MAXRED_SKIP;

    add.s32 %r19, %r3, %r18;            // t+stride
    mul.wide.s32 %rd22, %r19, 4;
    add.s64 %rd23, %rd7, %rd22;
    ld.shared.f32 %f6, [%rd23];         // redBuf[t+stride]
    ld.shared.f32 %f7, [%rd21];         // redBuf[t]
    setp.gt.f32 %p5, %f6, %f7;
    selp.f32 %f8, %f6, %f7, %p5;
    st.shared.f32 [%rd21], %f8;

BB_ATTN_MAXRED_SKIP:
    bar.sync 0;
    shr.u32 %r18, %r18, 1;
    bra BB_ATTN_MAXRED_LOOP;

BB_ATTN_MAXRED_DONE:
    ld.shared.f32 %f9, [%rd7];          // blockMax = redBuf[0]

    // ================= PHASE B: exponentiate =================
    mov.f32 %f10, 0f00000000;           // threadSum
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_EXP_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_EXP_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd19, %rd6, %rd18;
    ld.shared.f32 %f11, [%rd19];
    sub.f32 %f11, %f11, %f9;
    mul.f32 %f11, %f11, 0f3fb8aa3b;     // * log2(e)
    ex2.approx.f32 %f12, %f11;
    st.shared.f32 [%rd19], %f12;
    add.f32 %f10, %f10, %f12;

    add.s32 %r14, %r14, %r4;
    bra BB_ATTN_EXP_LOOP;

BB_ATTN_EXP_DONE:

    // ---- block-wide sum reduction ----
    st.shared.f32 [%rd21], %f10;        // redBuf[t] = threadSum
    bar.sync 0;

    shr.u32 %r18, %r4, 1;

BB_ATTN_SUMRED_LOOP:
    setp.eq.u32 %p3, %r18, 0;
    @%p3 bra BB_ATTN_SUMRED_DONE;

    setp.ge.u32 %p4, %r3, %r18;
    @%p4 bra BB_ATTN_SUMRED_SKIP;

    add.s32 %r19, %r3, %r18;
    mul.wide.s32 %rd22, %r19, 4;
    add.s64 %rd23, %rd7, %rd22;
    ld.shared.f32 %f6, [%rd23];
    ld.shared.f32 %f7, [%rd21];
    add.f32 %f8, %f6, %f7;
    st.shared.f32 [%rd21], %f8;

BB_ATTN_SUMRED_SKIP:
    bar.sync 0;
    shr.u32 %r18, %r18, 1;
    bra BB_ATTN_SUMRED_LOOP;

BB_ATTN_SUMRED_DONE:
    ld.shared.f32 %f13, [%rd7];         // blockSum = redBuf[0]
    rcp.approx.f32 %f14, %f13;          // invSum

    // ================= PHASE C: normalize + write S_matrix =================
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_NORM_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_NORM_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd19, %rd6, %rd18;
    ld.shared.f32 %f15, [%rd19];
    mul.f32 %f15, %f15, %f14;
    st.shared.f32 [%rd19], %f15;        // scores[j] = softmax weight

    add.s64 %rd24, %rd12, %rd18;
    st.global.f32 [%rd24], %f15;        // S_matrix[i,j] = weight

    add.s32 %r14, %r14, %r4;
    bra BB_ATTN_NORM_LOOP;

BB_ATTN_NORM_DONE:
    bar.sync 0;                         // dam bao scores[] ghi xong truoc khi Phase D doc

    // ================= PHASE D: Out[i,d] = sum_j weight_j * V[j,d] =================
    mov.u32 %r20, %r3;                  // d = t

BB_ATTN_OUT_D_LOOP:
    setp.ge.u32 %p3, %r20, %r8;
    @%p3 bra BB_ATTN_OUT_D_DONE;

    mov.f32 %f16, 0f00000000;           // acc
    mov.u32 %r14, 0;                    // j

BB_ATTN_OUT_J_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_OUT_J_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd19, %rd6, %rd18;
    ld.shared.f32 %f17, [%rd19];        // weight_j

    add.s32 %r15, %r10, %r14;           // bh*S+j
    mul.lo.s32 %r16, %r15, %r8;
    add.s32 %r21, %r16, %r20;           // (bh*S+j)*D + d
    mul.wide.s32 %rd25, %r21, 4;
    add.s64 %rd26, %rd3, %rd25;
    ld.global.nc.f32 %f18, [%rd26];     // V[j,d]

    fma.rn.f32 %f16, %f17, %f18, %f16;

    add.s32 %r14, %r14, 1;
    bra BB_ATTN_OUT_J_LOOP;

BB_ATTN_OUT_J_DONE:
    mul.wide.s32 %rd27, %r20, 4;
    add.s64 %rd28, %rd10, %rd27;
    st.global.f32 [%rd28], %f16;        // Out[i,d] = acc

    add.s32 %r20, %r20, %r4;            // d += ntid
    bra BB_ATTN_OUT_D_LOOP;

BB_ATTN_OUT_D_DONE:

BB_ATTN_RET:
    ret;
}

// ============================================================
// ATTENTION FUSED BACKWARD
// ============================================================
.visible .entry attention_fused_backward_kernel(
    .param .u64 attn_bwd_param_0,
    .param .u64 attn_bwd_param_1,
    .param .u64 attn_bwd_param_2,
    .param .u64 attn_bwd_param_3,
    .param .u64 attn_bwd_param_4,
    .param .u64 attn_bwd_param_5,
    .param .u64 attn_bwd_param_6,
    .param .u64 attn_bwd_param_7,
    .param .u32 attn_bwd_param_8,
    .param .u32 attn_bwd_param_9,
    .param .u32 attn_bwd_param_10,
    .param .u32 attn_bwd_param_11,
    .param .f32 attn_bwd_param_12
)
{
    .reg .pred %p<10>;
    .reg .b32 %r<100>;
    .reg .f32 %f<60>;
    .reg .b64 %rd<60>;
    .shared .align 4 .f32 softmaxW[256];
    .shared .align 4 .f32 dScoreArr[256];
    .shared .align 4 .f32 redBuf[512];

    // grid = (B*H, S, 1) ; block = (blockSize, 1, 1)
    // moi block xu ly grad cho 1 hang query (bh, i). dK/dV cong don qua nhieu block -> dung atomic add.
    mov.u32 %r1, %ctaid.x;      // bh
    mov.u32 %r2, %ctaid.y;      // i
    mov.u32 %r3, %tid.x;        // t
    mov.u32 %r4, %ntid.x;       // blockDim

    ld.param.u32 %r5, [attn_bwd_param_8];   // B
    ld.param.u32 %r6, [attn_bwd_param_9];   // H
    ld.param.u32 %r7, [attn_bwd_param_10];  // S
    ld.param.u32 %r8, [attn_bwd_param_11];  // D
    ld.param.f32 %f1, [attn_bwd_param_12];  // scale

    mul.lo.s32 %r9, %r5, %r6;           // B*H
    setp.ge.u32 %p1, %r1, %r9;
    @%p1 bra BB_ATTN_BWD_RET;
    setp.ge.u32 %p2, %r2, %r7;
    @%p2 bra BB_ATTN_BWD_RET;

    ld.param.u64 %rd1, [attn_bwd_param_0];  // Q
    ld.param.u64 %rd2, [attn_bwd_param_1];  // K
    ld.param.u64 %rd3, [attn_bwd_param_2];  // V
    ld.param.u64 %rd4, [attn_bwd_param_3];  // S_matrix
    ld.param.u64 %rd5, [attn_bwd_param_4];  // dY
    ld.param.u64 %rd6, [attn_bwd_param_5];  // dQ
    ld.param.u64 %rd7, [attn_bwd_param_6];  // dK
    ld.param.u64 %rd8, [attn_bwd_param_7];  // dV

    mov.u64 %rd9, softmaxW;
    mov.u64 %rd10, dScoreArr;
    mov.u64 %rd11, redBuf;

    mul.lo.s32 %r10, %r1, %r7;          // bh*S
    add.s32 %r11, %r10, %r2;            // rowIdx = bh*S+i
    mul.lo.s32 %r12, %r11, %r8;         // rowIdx*D
    mul.lo.s32 %r13, %r11, %r7;         // rowIdx*S

    mul.wide.s32 %rd12, %r12, 4;
    add.s64 %rd13, %rd1, %rd12;         // &Q[i,0]
    add.s64 %rd14, %rd5, %rd12;         // &dY[i,0]
    add.s64 %rd15, %rd6, %rd12;         // &dQ[i,0]
    mul.wide.s32 %rd16, %r13, 4;
    add.s64 %rd17, %rd4, %rd16;         // &S_matrix[i,0]

    // ================= PHASE A: softmaxW[j]=S_ij ; dScoreArr[j]=dS_ij=dY_i.V_j =================
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_BWD_LOAD_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_BWD_LOAD_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd19, %rd17, %rd18;
    ld.global.f32 %f2, [%rd19];         // S_ij
    add.s64 %rd20, %rd9, %rd18;
    st.shared.f32 [%rd20], %f2;         // softmaxW[j] = S_ij

    add.s32 %r15, %r10, %r14;           // bh*S+j
    mul.lo.s32 %r16, %r15, %r8;         // (bh*S+j)*D
    mul.wide.s32 %rd21, %r16, 4;
    add.s64 %rd22, %rd3, %rd21;         // &V[j,0]

    mov.f32 %f3, 0f00000000;            // dS accum
    mov.u32 %r17, 0;                    // d

BB_ATTN_BWD_DS_LOOP:
    setp.ge.u32 %p3, %r17, %r8;
    @%p3 bra BB_ATTN_BWD_DS_DONE;

    mul.wide.s32 %rd23, %r17, 4;
    add.s64 %rd24, %rd14, %rd23;
    ld.global.nc.f32 %f4, [%rd24];      // dY[i,d]
    add.s64 %rd25, %rd22, %rd23;
    ld.global.nc.f32 %f5, [%rd25];      // V[j,d]
    fma.rn.f32 %f3, %f4, %f5, %f3;

    add.s32 %r17, %r17, 1;
    bra BB_ATTN_BWD_DS_LOOP;

BB_ATTN_BWD_DS_DONE:
    add.s64 %rd26, %rd10, %rd18;
    st.shared.f32 [%rd26], %f3;         // dScoreArr[j] = dS_ij (tam)

    add.s32 %r14, %r14, %r4;            // j += ntid
    bra BB_ATTN_BWD_LOAD_LOOP;

BB_ATTN_BWD_LOAD_DONE:
    bar.sync 0;                         // dam bao softmaxW/dScoreArr day du truoc khi reduce

    // ================= PHASE B: rowdot = sum_j softmaxW[j]*dScoreArr[j] =================
    mov.f32 %f6, 0f00000000;            // threadDot
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_BWD_DOT_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_BWD_DOT_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd20, %rd9, %rd18;
    ld.shared.f32 %f7, [%rd20];         // softmaxW[j]
    add.s64 %rd26, %rd10, %rd18;
    ld.shared.f32 %f8, [%rd26];         // dScoreArr[j] (dS_ij)
    fma.rn.f32 %f6, %f7, %f8, %f6;

    add.s32 %r14, %r14, %r4;
    bra BB_ATTN_BWD_DOT_LOOP;

BB_ATTN_BWD_DOT_DONE:

    // ---- block-wide sum reduction -> rowdot ----
    mul.wide.s32 %rd27, %r3, 4;
    add.s64 %rd28, %rd11, %rd27;
    st.shared.f32 [%rd28], %f6;         // redBuf[t] = threadDot
    bar.sync 0;

    shr.u32 %r18, %r4, 1;

BB_ATTN_BWD_SUMRED_LOOP:
    setp.eq.u32 %p3, %r18, 0;
    @%p3 bra BB_ATTN_BWD_SUMRED_DONE;

    setp.ge.u32 %p4, %r3, %r18;
    @%p4 bra BB_ATTN_BWD_SUMRED_SKIP;

    add.s32 %r19, %r3, %r18;
    mul.wide.s32 %rd29, %r19, 4;
    add.s64 %rd30, %rd11, %rd29;
    ld.shared.f32 %f9, [%rd30];
    ld.shared.f32 %f10, [%rd28];
    add.f32 %f11, %f9, %f10;
    st.shared.f32 [%rd28], %f11;

BB_ATTN_BWD_SUMRED_SKIP:
    bar.sync 0;
    shr.u32 %r18, %r18, 1;
    bra BB_ATTN_BWD_SUMRED_LOOP;

BB_ATTN_BWD_SUMRED_DONE:
    ld.shared.f32 %f12, [%rd11];        // rowdot = redBuf[0]

    // ================= PHASE C: dScoreArr[j] = softmaxW[j]*(dScoreArr[j]-rowdot) =================
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_BWD_DSCORE_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_BWD_DSCORE_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd20, %rd9, %rd18;
    ld.shared.f32 %f13, [%rd20];        // softmaxW[j]
    add.s64 %rd26, %rd10, %rd18;
    ld.shared.f32 %f14, [%rd26];        // dS_ij
    sub.f32 %f15, %f14, %f12;
    mul.f32 %f15, %f13, %f15;
    st.shared.f32 [%rd26], %f15;        // dScoreArr[j] = dScore cuoi cung

    add.s32 %r14, %r14, %r4;
    bra BB_ATTN_BWD_DSCORE_LOOP;

BB_ATTN_BWD_DSCORE_DONE:
    bar.sync 0;                         // dam bao dScoreArr[] day du truoc Phase D/E

    // ================= PHASE D: dQ[i,d] = scale * sum_j dScoreArr[j]*K[j,d] =================
    mov.u32 %r20, %r3;                  // d = t

BB_ATTN_BWD_DQ_D_LOOP:
    setp.ge.u32 %p3, %r20, %r8;
    @%p3 bra BB_ATTN_BWD_DQ_D_DONE;

    mov.f32 %f16, 0f00000000;           // acc
    mov.u32 %r14, 0;                    // j

BB_ATTN_BWD_DQ_J_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_BWD_DQ_J_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd26, %rd10, %rd18;
    ld.shared.f32 %f17, [%rd26];        // dScoreArr[j]

    add.s32 %r15, %r10, %r14;           // bh*S+j
    mul.lo.s32 %r16, %r15, %r8;
    add.s32 %r21, %r16, %r20;           // (bh*S+j)*D + d
    mul.wide.s32 %rd31, %r21, 4;
    add.s64 %rd32, %rd2, %rd31;
    ld.global.nc.f32 %f18, [%rd32];     // K[j,d]

    fma.rn.f32 %f16, %f17, %f18, %f16;

    add.s32 %r14, %r14, 1;
    bra BB_ATTN_BWD_DQ_J_LOOP;

BB_ATTN_BWD_DQ_J_DONE:
    mul.f32 %f16, %f16, %f1;            // * scale
    mul.wide.s32 %rd33, %r20, 4;
    add.s64 %rd34, %rd15, %rd33;
    st.global.f32 [%rd34], %f16;        // dQ[i,d] = acc (khong dung, moi block ghi rieng)

    add.s32 %r20, %r20, %r4;            // d += ntid
    bra BB_ATTN_BWD_DQ_D_LOOP;

BB_ATTN_BWD_DQ_D_DONE:

    // ================= PHASE E: dK[j,d] += dScoreArr[j]*scale*Q[i,d] ; dV[j,d] += softmaxW[j]*dY[i,d] =================
    // (nhieu block khac nhau (bh cung, i khac) co the ghi cung [j,d] -> BAT BUOC atomic)
    mov.u32 %r14, %r3;                  // j = t

BB_ATTN_BWD_DKV_J_LOOP:
    setp.ge.u32 %p3, %r14, %r7;
    @%p3 bra BB_ATTN_BWD_DKV_J_DONE;

    mul.wide.s32 %rd18, %r14, 4;
    add.s64 %rd26, %rd10, %rd18;
    ld.shared.f32 %f19, [%rd26];        // dScoreArr[j]
    mul.f32 %f20, %f19, %f1;            // dScoreArr[j]*scale

    add.s64 %rd20, %rd9, %rd18;
    ld.shared.f32 %f21, [%rd20];        // softmaxW[j]

    add.s32 %r15, %r10, %r14;           // bh*S+j
    mul.lo.s32 %r16, %r15, %r8;         // (bh*S+j)*D

    mov.u32 %r22, 0;                    // d

BB_ATTN_BWD_DKV_D_LOOP:
    setp.ge.u32 %p3, %r22, %r8;
    @%p3 bra BB_ATTN_BWD_DKV_D_DONE;

    add.s32 %r23, %r16, %r22;           // (bh*S+j)*D + d
    mul.wide.s32 %rd35, %r23, 4;

    mul.wide.s32 %rd36, %r22, 4;
    add.s64 %rd37, %rd13, %rd36;
    ld.global.nc.f32 %f22, [%rd37];     // Q[i,d]
    mul.f32 %f23, %f20, %f22;           // dScoreArr[j]*scale*Q[i,d]
    add.s64 %rd38, %rd7, %rd35;
    atom.global.add.f32 %f24, [%rd38], %f23;   // dK[j,d] += ...

    add.s64 %rd39, %rd14, %rd36;
    ld.global.nc.f32 %f25, [%rd39];     // dY[i,d]
    mul.f32 %f26, %f21, %f25;           // softmaxW[j]*dY[i,d]
    add.s64 %rd40, %rd8, %rd35;
    atom.global.add.f32 %f27, [%rd40], %f26;   // dV[j,d] += ...

    add.s32 %r22, %r22, 1;
    bra BB_ATTN_BWD_DKV_D_LOOP;

BB_ATTN_BWD_DKV_D_DONE:
    add.s32 %r14, %r14, %r4;            // j += ntid
    bra BB_ATTN_BWD_DKV_J_LOOP;

BB_ATTN_BWD_DKV_J_DONE:

BB_ATTN_BWD_RET:
    ret;
}
